rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner' ||
         (request.auth.token.email == "cr4643308@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isManager() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.ghiCoins is number && data.ghiCoins >= 0 &&
             data.role in ['user', 'manager', 'owner'] &&
             (!('claimedEvents' in data) || data.claimedEvents is list);
    }
    
    function isValidEvent(data) {
      return data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.rewardAmount is number && data.rewardAmount > 0 &&
             data.createdBy is string && data.createdBy.size() > 0 && data.createdBy.size() < 100 &&
             data.isActive is bool;
    }

    // ===============================================================
    // Collections
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isManager();
      
      // Allow user to create their own profile with 0 coins and 'user' role
      allow create: if isOwner(userId) && 
                       isValidUser(request.resource.data) && 
                       request.resource.data.ghiCoins == 0 && 
                       request.resource.data.role == 'user' &&
                       request.resource.data.uid == userId;
                       
      // Allow user to update their own coins, but not their role. 
      // Admin can update anything.
      allow update: if (isOwner(userId) && 
                        isValidUser(request.resource.data) && 
                        request.resource.data.role == resource.data.role && // Cannot change role
                        request.resource.data.uid == resource.data.uid) || // Cannot change uid
                       (isAdmin() && isValidUser(request.resource.data));
                       
      allow delete: if isAdmin();
    }
    
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create, update: if (isAdmin() || isManager()) && isValidEvent(request.resource.data);
      allow delete: if isAdmin() || isManager();
    }
  }
}
